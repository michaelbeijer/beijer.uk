---
interface Props {
  pageUrl: string;
  pageTitle: string;
}

const { pageUrl, pageTitle } = Astro.props;

const issoHost = 'https://comments.michaelbeijer.co.uk';
---

<section class="comments-section">
  <h2>Comments</h2>
  <section
    id="isso-thread"
    data-title={pageTitle}
  ></section>
</section>

<script
  is:inline
  define:vars={{ issoHost }}
  data-isso-css="true"
  data-isso-avatar="false"
  data-isso-vote="false"
  data-isso-reply-notifications-default-enabled="true"
  data-isso-max-comments-top="inf"
  data-isso-max-comments-nested="5"
>
  // data- attributes on <script> tags with define:vars are not passed through,
  // so we dynamically create and insert the Isso embed script with the correct attributes.
  (function() {
    var d = document, s = d.createElement('script');
    s.src = issoHost + '/js/embed.min.js';
    s.defer = true;
    s.setAttribute('data-isso', issoHost + '/');
    s.setAttribute('data-isso-css', 'true');
    s.setAttribute('data-isso-avatar', 'false');
    s.setAttribute('data-isso-vote', 'false');
    s.setAttribute('data-isso-reply-notifications-default-enabled', 'true');
    s.setAttribute('data-isso-max-comments-top', 'inf');
    s.setAttribute('data-isso-max-comments-nested', '5');
    (d.head || d.body).appendChild(s);

    // Fix "E-mail" → "Email" once Isso renders
    var mo = new MutationObserver(function() {
      d.querySelectorAll('#isso-thread label').forEach(function(l) {
        if (l.textContent.trim() === 'E-mail (optional)') l.textContent = 'Email (optional)';
      });
    });
    var target = d.getElementById('isso-thread');
    if (target) mo.observe(target, { childList: true, subtree: true });
  })();
</script>

<style>
  .comments-section {
    margin-top: 3em;
    padding-top: 2em;
    border-top: 1px solid rgb(var(--border));
  }
  .comments-section h2 {
    font-size: 1.4em;
    margin-bottom: 1em;
    color: rgb(var(--text));
  }

  /* Hide Isso's "N Comment(s)" heading — we already have our own */
  #isso-thread :global(h4) {
    display: none;
  }

  /* Override Isso defaults to match site design */
  #isso-thread :global(.isso-postbox .isso-textarea) {
    font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: 15px;
    border: 1px solid rgb(var(--border));
    border-radius: 6px;
    padding: 0.5em 0.75em;
    background: white;
    min-height: 100px;
    transition: border-color 0.2s;
  }
  #isso-thread :global(.isso-postbox .isso-textarea:focus) {
    outline: none;
    border-color: rgb(var(--accent));
  }
  #isso-thread :global(.isso-postbox .isso-input-wrapper input) {
    font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: 15px;
    border: 1px solid rgb(var(--border));
    border-radius: 6px;
    padding: 0.5em 0.75em;
    background: white;
    transition: border-color 0.2s;
  }
  #isso-thread :global(.isso-postbox .isso-input-wrapper input:focus) {
    outline: none;
    border-color: rgb(var(--accent));
  }
  #isso-thread :global(.isso-postbox .isso-post-action input[type="submit"]) {
    background-color: rgb(var(--text));
    color: white;
    border: none;
    border-radius: 6px;
    padding: 0.6em 1.4em;
    font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: 14px;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  #isso-thread :global(.isso-postbox .isso-post-action input[type="submit"]:hover) {
    opacity: 0.8;
  }
  #isso-thread :global(.isso-comment) {
    font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }
  #isso-thread :global(.isso-comment .isso-comment-header .isso-spacer),
  #isso-thread :global(.isso-comment .isso-comment-header a) {
    font-size: 0.85em;
    color: rgb(var(--muted));
  }
  #isso-thread :global(.isso-comment .isso-text p) {
    margin-bottom: 0.5em;
  }
</style>
