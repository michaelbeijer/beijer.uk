---
import Page from '../../layouts/Page.astro';
import { SITE_SEO_TITLE } from '../../consts';

// Beijerterm's canonical home is beijerterm.com. This page is a LAUNCHER, not
// a second search engine: the form hands off to beijerterm.com (results live
// there — no duplicate content), and the canonical URL points there too.
const BEIJERTERM = 'https://beijerterm.com';
---

<Page
	title={`Beijerterm | ${SITE_SEO_TITLE}`}
	description="Beijerterm — my curated multilingual terminology database for technical translators. Search it on beijerterm.com or inside Supervertaler."
	canonical={`${BEIJERTERM}/`}
>
	<section class="bt">
		<h1>Beijerterm</h1>
		<p class="bt-lede">
			My curated, searchable multilingual terminology database for technical
			translators — Dutch&nbsp;↔&nbsp;English and more, with full provenance for
			every source.
		</p>

		<form class="bt-search" action={`${BEIJERTERM}/`} method="get">
			<input
				id="bt-q"
				name="q"
				type="search"
				placeholder="Search Beijerterm…"
				autocomplete="off"
				spellcheck="false"
				aria-label="Search Beijerterm"
			/>
			<input type="hidden" name="from" id="bt-from" value="nl" />
			<input type="hidden" name="to" id="bt-to" value="en" />
			<div class="bt-controls">
				<div class="bt-dir" role="group" aria-label="Search direction">
					<button type="button" data-from="nl" data-to="en" class="active">Dutch → English</button>
					<button type="button" data-from="en" data-to="nl">English → Dutch</button>
				</div>
				<button type="submit" class="bt-go">Search Beijerterm ↗</button>
			</div>
			<p class="bt-hint">Your search opens on <strong>beijerterm.com</strong>.</p>
		</form>

		<p class="bt-open"><a href={`${BEIJERTERM}/`}>Open the full Beijerterm site ↗</a></p>
	</section>

	<section class="bt-about">
		<h2>Three ways to search it</h2>
		<ul>
			<li><strong>Here</strong> — type above and you jump straight to the results on beijerterm.com.</li>
			<li><strong><a href={`${BEIJERTERM}/`}>beijerterm.com</a></strong> — the full site: every source, with its publication metadata and provenance.</li>
			<li><strong>Inside Supervertaler</strong> — Beijerterm is a SuperLookup resource in Supervertaler Workbench and Supervertaler for Trados, so it's one keystroke away while you translate.</li>
		</ul>
		<p><a href={`${BEIJERTERM}/`}>See the glossaries and term lists behind it →</a></p>
	</section>
</Page>

<style>
	.bt { margin-bottom: 2.5em; }
	.bt h1 { margin-bottom: 0.15em; }
	.bt-lede { color: rgb(var(--muted)); margin-top: 0; line-height: 1.6; }
	.bt-search { margin-top: 1.6em; }
	#bt-q {
		width: 100%;
		font-size: 1.15em;
		padding: 0.7em 0.9em;
		border: 1px solid rgb(var(--border));
		border-radius: 8px;
		box-sizing: border-box;
		font-family: inherit;
		background: rgb(var(--bg));
		color: rgb(var(--text));
	}
	#bt-q:focus { outline: none; border-color: rgb(var(--text)); }
	.bt-controls {
		display: flex;
		align-items: center;
		gap: 0.6em;
		margin-top: 0.6em;
		flex-wrap: wrap;
	}
	.bt-dir { display: inline-flex; gap: 0.25em; }
	.bt-dir button {
		font: inherit;
		font-size: 0.8em;
		padding: 0.3em 0.8em;
		border: 1px solid rgb(var(--border));
		border-radius: 99px;
		background: transparent;
		color: rgb(var(--muted));
		cursor: pointer;
	}
	.bt-dir button.active {
		background: rgb(var(--text));
		color: rgb(var(--bg));
		border-color: rgb(var(--text));
	}
	.bt-go {
		font: inherit;
		font-weight: 600;
		padding: 0.5em 1.1em;
		cursor: pointer;
		border: 1px solid rgb(var(--accent));
		border-radius: 8px;
		background: rgb(var(--accent));
		color: #fff;
	}
	.bt-hint { font-size: 0.82em; color: rgb(var(--muted)); margin: 0.6em 0 0; }
	.bt-open { margin-top: 1.1em; }
	.bt-about h2 { font-size: 1.3em; margin-bottom: 0.3em; }
	.bt-about ul { line-height: 1.7; padding-left: 1.2em; }
	.bt-about li { margin-bottom: 0.3em; }
</style>

<script define:vars={{ BEIJERTERM }}>
	// Progressive enhancement: the form already submits as a GET to
	// beijerterm.com (works with no JS at all). JS just lets the direction
	// chips set the from/to params and keeps focus tidy.
	const fromEl = document.getElementById('bt-from');
	const toEl = document.getElementById('bt-to');
	const q = document.getElementById('bt-q');
	const btns = document.querySelectorAll('.bt-dir button');
	btns.forEach((b) => {
		b.addEventListener('click', () => {
			fromEl.value = b.dataset.from;
			toEl.value = b.dataset.to;
			btns.forEach((x) => x.classList.toggle('active', x === b));
			q.focus();
		});
	});
	// Press '/' to focus the box, like the main site.
	document.addEventListener('keydown', (ev) => {
		if (ev.key === '/' && document.activeElement !== q) {
			const tag = (document.activeElement?.tagName || '').toLowerCase();
			if (tag !== 'input' && tag !== 'textarea') {
				ev.preventDefault();
				q.focus();
			}
		}
	});
</script>
