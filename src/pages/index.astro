---
import BackToTop from '../components/BackToTop.astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { getEntry, render } from 'astro:content';
import {
	CONTACT_EMAIL,
	PROZ_FEEDBACK_URL,
	SITE_DESCRIPTION,
	SITE_SEO_TITLE,
} from '../consts';

const base = import.meta.env.BASE_URL;
const home = await getEntry('home', 'index');
if (!home) throw new Error('home/index.md not found');
const { Content } = await render(home);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_SEO_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>{home.data.title}</h1>
			<p class="lead">{home.data.tagline}</p>
			<p class="intro">{home.data.intro}</p>
			<div class="cta">
				<a class="button" href={base + 'contact'}>Email me</a>
				<a class="button secondary" href={PROZ_FEEDBACK_URL} target="_blank" rel="noopener">ProZ feedback</a>
			</div>
			<p class="subtle-links">
				<a href={base + 'about'}>About</a>
				<span aria-hidden="true">·</span>
				<a href={base + 'work'}>Work</a>
			</p>
			<hr />
			<div class="home-content">
				<Content />
			</div>
		</main>
		<Footer />
		<BackToTop />
	</body>
</html>

<style>
	.lead {
		font-size: 1.1em;
		color: rgb(var(--muted));
		line-height: 1.85;
	}
	.intro {
		line-height: 1.85;
	}
	.cta {
		display: flex;
		gap: 0.75em;
		flex-wrap: wrap;
		margin: 1.25em 0;
	}
	.button {
		display: inline-block;
		padding: 0.6em 0.9em;
		border: 1px solid rgb(var(--text));
		border-radius: 6px;
		text-decoration: none;
		color: rgb(var(--bg));
		background: rgb(var(--text));
		box-shadow: var(--box-shadow);
	}
	.button:hover {
		opacity: 0.9;
	}
	.button.secondary {
		background: rgb(var(--bg));
		color: rgb(var(--text));
	}
	.subtle-links {
		margin: -0.25em 0 1.25em 0;
		color: rgb(var(--muted));
		font-size: 0.95em;
	}
	.subtle-links a {
		color: rgb(var(--muted));
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 3px;
	}
	.subtle-links a:hover {
		color: rgb(var(--text));
	}
	.subtle-links span {
		margin: 0 0.5em;
	}
	.home-content :global(ul) {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.home-content :global(li) {
		margin: 0.5em 0;
	}
</style>
