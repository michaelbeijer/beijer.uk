---
import BackToTop from '../components/BackToTop.astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { getEntry, render } from 'astro:content';
import {
	CONTACT_EMAIL,
	PROZ_FEEDBACK_URL,
	SITE_DESCRIPTION,
	SITE_SEO_TITLE,
} from '../consts';

const base = import.meta.env.BASE_URL;
const home = await getEntry('home', 'index');
if (!home) throw new Error('home/index.md not found');
const { Content } = await render(home);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_SEO_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-text">
					<h1>{home.data.title}</h1>
					<p class="lead">{home.data.tagline}</p>
					<p class="intro" set:html={home.data.intro.replace(/\n/g, '<br>')} />
					<div class="cta">
						<a class="button" href={base + 'contact'}>Email me</a>
						<a class="button secondary" href={PROZ_FEEDBACK_URL} target="_blank" rel="noopener">ProZ feedback</a>
					</div>
				</div>
				<img
					class="hero-photo"
					src={base + 'blog-images/michael-beijer.jpg'}
					alt="Michael Beijer"
					width="600"
					height="643"
					loading="eager"
				/>
			</section>
			<div class="home-content">
				<Content />
			</div>
		</main>
		<Footer />
		<BackToTop />
	</body>
</html>

<style>
	.hero {
		display: flex;
		gap: 2rem;
		align-items: flex-start;
		margin-bottom: 1em;
	}
	.hero-text {
		flex: 1;
		min-width: 0;
	}
	.hero-photo {
		width: 220px;
		height: auto;
		border-radius: 8px;
		flex-shrink: 0;
	}
	@media (max-width: 600px) {
		.hero {
			flex-direction: column-reverse;
			align-items: center;
			gap: 1.5rem;
		}
		.hero-photo {
			width: 180px;
		}
	}
	.lead {
		font-size: 1.1em;
		color: rgb(var(--muted));
		line-height: 1.85;
	}
	.intro {
		line-height: 1.85;
	}
	.cta {
		display: flex;
		gap: 0.75em;
		flex-wrap: wrap;
		margin: 1.25em 0;
	}
	.button {
		display: inline-block;
		padding: 0.6em 0.9em;
		border: 1px solid rgb(var(--text));
		border-radius: 6px;
		text-decoration: none;
		color: rgb(var(--bg));
		background: rgb(var(--text));
		box-shadow: var(--box-shadow);
	}
	.button:hover {
		opacity: 0.9;
	}
	.button.secondary {
		background: rgb(var(--bg));
		color: rgb(var(--text));
	}
	.home-content :global(ul) {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.home-content :global(li) {
		margin: 0.5em 0;
	}
</style>
