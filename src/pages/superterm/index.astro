---
import Page from '../../layouts/Page.astro';
import { SITE_SEO_TITLE } from '../../consts';

// superterm.io is the canonical site. This page is a PREVIEW + link, not a
// search box: a screenshot of the real tool, a short blurb, and a button.
const SUPERTERM = 'https://superterm.io';
---

<Page
	title={`Superterm | ${SITE_SEO_TITLE}`}
	description="Superterm — my curated multilingual terminology database for technical translators. Search it free at superterm.io, or inside Supervertaler."
	canonical={`${SUPERTERM}/`}
>
	<section class="bt">
		<h1>Superterm</h1>
		<p class="bt-lede">
			My curated, searchable multilingual terminology database for technical
			translators — Dutch&nbsp;↔&nbsp;English and more, with full provenance for
			every source. Free to search, and built into Supervertaler.
		</p>

		<p class="bt-cta">
			<a class="bt-btn" href={`${SUPERTERM}/`}>Open Superterm ↗</a>
		</p>

		<a class="bt-shot" href={`${SUPERTERM}/`} aria-label="Open Superterm">
			<img
				src="/superterm-preview.png?v=2"
				width="1280"
				height="820"
				alt="The Superterm terminology search at superterm.io — a search box with matching terms below, and a Sources tab listing every glossary behind the database."
			/>
		</a>

		<p class="bt-foot">
			Search it at <a href={`${SUPERTERM}/`}>superterm.io</a>, or one keystroke
			away as a SuperLookup resource inside Supervertaler Workbench and Supervertaler
			for Trados.
		</p>
	</section>
</Page>

<style>
	.bt { margin-bottom: 2.5em; }
	.bt h1 { margin-bottom: 0.2em; }
	.bt-lede {
		color: rgb(var(--muted));
		margin-top: 0;
		line-height: 1.65;
		max-width: 42em;
	}
	.bt-cta { margin: 1.4em 0; }
	.bt-btn {
		display: inline-block;
		font-weight: 600;
		font-size: 1.05em;
		padding: 0.6em 1.3em;
		border-radius: 8px;
		background: rgb(var(--text));
		color: rgb(var(--bg));
		text-decoration: none;
		border: 1px solid rgb(var(--text));
	}
	.bt-btn:hover { opacity: 0.85; }
	.bt-shot {
		display: block;
		border-radius: 10px;
	}
	.bt-shot img {
		display: block;
		width: 100%;
		height: auto;
		border: 1px solid rgb(var(--border));
		border-radius: 10px;
		box-shadow: 0 2px 16px rgba(0, 0, 0, 0.08);
	}
	.bt-foot {
		margin-top: 1.4em;
		color: rgb(var(--muted));
		font-size: 0.92em;
		line-height: 1.6;
		max-width: 42em;
	}
</style>
