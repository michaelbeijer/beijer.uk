---
import Page from '../layouts/Page.astro';
import { getEntry, render } from 'astro:content';
import { CONTACT_EMAIL, SITE_SEO_TITLE } from '../consts';

const page = await getEntry('pages', 'services');
if (!page) throw new Error('services.md not found');
const { Content } = await render(page);
---

<Page title={`${page.data.title} | ${SITE_SEO_TITLE}`} description={page.data.description}>
	<h1>{page.data.title}</h1>
	<Content />
	<hr />
	<p>
		Email: <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>.
	</p>
</Page>
