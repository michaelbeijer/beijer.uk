---
import Page from '../layouts/Page.astro';
import { getEntry, render } from 'astro:content';
import { PROZ_FEEDBACK_URL, SITE_SEO_TITLE } from '../consts';

const page = await getEntry('pages', 'testimonials');
if (!page) throw new Error('testimonials.md not found');
const { Content } = await render(page);
---

<Page title={`${page.data.title} | ${SITE_SEO_TITLE}`} description={page.data.description}>
	<h1>{page.data.title}</h1>
	<Content />
	<hr />
	<p>
		<a href={PROZ_FEEDBACK_URL} target="_blank" rel="noopener">View all feedback on ProZ.com →</a>
	</p>
</Page>

<style>
	blockquote {
		margin: 1em 0;
		padding: 0.5em 1em;
		border-left: 3px solid rgb(var(--muted));
		background: rgba(var(--muted), 0.05);
	}
	blockquote p {
		margin: 0 0 0.5em 0;
		font-style: italic;
	}
	blockquote cite {
		font-size: 0.9em;
		color: rgb(var(--muted));
	}
</style>
